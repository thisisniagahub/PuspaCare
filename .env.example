# ═══════════════════════════════════════════════════════════════════
# PUSPA NGO Management System — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT:
#   Uses SQLite — just run `bun run dev` and it works.
#   No extra env vars needed.
#
# VERCEL PRODUCTION (via Vercel Supabase Integration):
#   Add Supabase as a Vercel integration → env vars auto-set.
#   The build script auto-detects SUPABASE_DB_URL.
#
# VERCEL PRODUCTION (manual Supabase setup):
#   Add these in Vercel Dashboard → Settings → Environment Variables:
#     DATABASE_URL = (connection pooler URL)
#     DIRECT_URL   = (direct connection URL)
# ═══════════════════════════════════════════════════════════════════

# ── Option A: Vercel Supabase Integration (auto-provided) ────
# No manual config needed — Vercel sets these automatically:
#   SUPABASE_DB_URL
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY

# ── Option B: Manual Supabase PostgreSQL ────────────────────
# Connection pooler (for app runtime):
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Direct connection (for migrations):
# DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres?sslmode=require"

# ── Supabase Client (for real-time features, optional) ─────
# NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# ── Local SQLite (default, no changes needed) ──────────────
# DATABASE_URL=file:./db/custom.db
# DIRECT_URL=file:./db/custom.db

# ── API Security ───────────────────────────────────────────
# Required in production for /api/v1/* routes.
# Requests must include this key in the X-API-Key header.
# In development, the middleware is bypassed automatically.
# API_SECRET_KEY=your-secret-api-key-here
# PUSPA_SESSION_SECRET=your-long-random-session-secret
# PUSPA_OPERATOR_PASSWORD=your-operator-password
# PUSPA_OPERATOR_ROLE=developer

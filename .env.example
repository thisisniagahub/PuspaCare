# ═══════════════════════════════════════════════════════════════════
# PUSPA NGO Management System — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT (default):
#   Uses SQLite — just run `bun run dev` and it works.
#
# VERCEL PRODUCTION:
#   Uses Supabase PostgreSQL — add these variables in Vercel dashboard.
#   See: https://vercel.com/[your-app]/settings/environment-variables
#
# HOW TO GET SUPABASE CREDENTIALS:
#   1. Go to https://supabase.com/dashboard
#   2. Select your project
#   3. Settings → Database → Connection string → URI
#      → That's your DIRECT_URL
#   4. Settings → Database → Connection string → Transaction pooler
#      → That's your DATABASE_URL
#   5. Settings → API → Project URL + anon public key
#      → That's NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY
# ═══════════════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ─────────────────────────────
# Connection pooler for app runtime (Vercel serverless)
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection for migrations (Prisma db push/seed)
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres?sslmode=require"

# ── Supabase Client (optional, for real-time) ───────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY-FROM-API-SETTINGS]"

# ── Local SQLite (override for local dev) ────────────────────────
# DATABASE_URL="file:./db/custom.db"
# DIRECT_URL="file:./db/custom.db"

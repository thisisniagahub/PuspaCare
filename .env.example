# PUSPA NGO Management System — Environment Variables
# Copy this file to .env.local and fill in the values

# ═══════════════════════════════════════════════════════
# DATABASE — Supabase PostgreSQL (for Vercel production)
# ═══════════════════════════════════════════════════════
# Connection pooler URL (for serverless/edge functions)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection URL (for migrations/seeding)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres?sslmode=require"

# ═══════════════════════════════════════════════════════
# LOCAL DEVELOPMENT — SQLite
# ═══════════════════════════════════════════════════════
# For local dev with SQLite, override both URLs:
# DATABASE_URL="file:./db/custom.db"
# DIRECT_URL="file:./db/custom.db"
# And change prisma schema provider to "sqlite"

# ═══════════════════════════════════════════════════════
# SUPABASE (for client-side features, optional)
# ═══════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your-anon-key]"

# ═══════════════════════════════════════════════════════
# NEXTAUTH (when implemented)
# ═══════════════════════════════════════════════════════
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXTAUTH_SECRET=your-secret-key-here
